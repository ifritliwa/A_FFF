_ctx$ = 8						; size = 4
_key$ = 12						; size = 4
_des_set_key PROC					; COMDAT

; 336  : {

  00000	55		 push	 ebp
  00001	8b ec		 mov	 ebp, esp
  00003	56		 push	 esi

; 337  :     int i;
; 338  : 
; 339  :     /* setup encryption subkeys */
; 340  : 
; 341  :     des_main_ks( ctx->esk, key );

  00004	ff 75 0c	 push	 DWORD PTR _key$[ebp]
  00007	8b 75 08	 mov	 esi, DWORD PTR _ctx$[ebp]
  0000a	56		 push	 esi
  0000b	e8 00 00 00 00	 call	 _des_main_ks
  00010	8d 96 84 00 00
	00		 lea	 edx, DWORD PTR [esi+132]
  00016	83 c4 08	 add	 esp, 8
  00019	8d 46 7c	 lea	 eax, DWORD PTR [esi+124]
  0001c	be 10 00 00 00	 mov	 esi, 16			; 00000010H
$LL4@des_set_ke:

; 342  : 
; 343  :     /* setup decryption subkeys */
; 344  : 
; 345  :     for( i = 0; i < 32; i += 2 )
; 346  :     {
; 347  :         ctx->dsk[i    ] = ctx->esk[30 - i];

  00021	8b 48 fc	 mov	 ecx, DWORD PTR [eax-4]
  00024	8d 52 08	 lea	 edx, DWORD PTR [edx+8]
  00027	89 4a f4	 mov	 DWORD PTR [edx-12], ecx
  0002a	8d 40 f8	 lea	 eax, DWORD PTR [eax-8]

; 348  :         ctx->dsk[i + 1] = ctx->esk[31 - i];

  0002d	8b 48 08	 mov	 ecx, DWORD PTR [eax+8]
  00030	89 4a f8	 mov	 DWORD PTR [edx-8], ecx
  00033	83 ee 01	 sub	 esi, 1
  00036	75 e9		 jne	 SHORT $LL4@des_set_ke

; 349  :     }
; 350  : 
; 351  :     return( 0 );

  00038	5e		 pop	 esi
  00039	33 c0		 xor	 eax, eax

; 352  : }

  0003b	5d		 pop	 ebp
  0003c	c3		 ret	 0
_des_set_key ENDP
_TEXT	ENDS
END
