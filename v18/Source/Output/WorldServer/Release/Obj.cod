; 246  : 		m_pModel->FrameMove( &vPos );		// żůµĺĽ­ąöżˇĽ± CObj::m_pModelŔÇ FrameMove¸¦ µą¸±ÇĘżä ľř´Ů.
; 247  : 	}
; 248  : 
; 249  : 	if( m_pModel->m_pModelElem->m_bTrans )
