; 251  : 		D3DXVECTOR3 vPosObj, vPosAct, vPosCam;
; 252  : 		float fLengthObj, fLengthAct;
; 253  : 		if( GetActiveObj() != NULL )
; 254  : 		{
; 255  : 			vPosCam = m_pWorld->m_pCamera->m_vPos;
; 256  : 			vPosObj = GetPos() - vPosCam;
; 257  : 			vPosAct = GetActiveObj()->GetPos() - vPosCam;
; 258  : 			fLengthObj = D3DXVec3LengthSq( &vPosObj );	// Length¸¦ LengthSq·Î ąŮ˛Ţ. xuzhu
; 259  : 			fLengthAct = D3DXVec3LengthSq( &vPosAct );
; 260  : 		}		
