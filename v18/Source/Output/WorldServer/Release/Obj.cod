; 273  : 			}
; 274  : 			else
; 275  : 			{
; 276  : 				m_wBlendFactor+=10;
; 277  : 				if( m_wBlendFactor > 255 ) m_wBlendFactor = 255;
; 278  : 			}
; 279  : 		}
; 280  : 		else
; 281  : 		{
; 282  : 			m_wBlendFactor+=5;
; 283  : 			if( m_wBlendFactor > 255 ) m_wBlendFactor = 255;
; 284  : 		}
; 285  : 	} 
