; 267  : 			D3DXVECTOR3 vPickRayDir = vPosAct;
; 268  : 			D3DXVec3Normalize( &( vPickRayDir ), &( vPickRayDir ) );
; 269  : 			if( Pick( &vPosCam, &vPickRayDir, &vIntersect, &fDist, FALSE, FALSE ) )
