; 608  : 	void SetString(
; 609  : 		_In_reads_opt_(nLength) PCXSTR pszSrc,
; 610  : 		_In_ int nLength)
; 611  : 	{
; 612  : 		if( nLength == 0 )
; 613  : 		{
; 614  : 			Empty();
; 615  : 		}
; 616  : 		else
; 617  : 		{
; 618  : 			// It is possible that pszSrc points to a location inside of our
; 619  : 			// buffer.  GetBuffer() might change m_pszData if (1) the buffer
; 620  : 			// is shared or (2) the buffer is too small to hold the new
; 621  : 			// string.  We detect this aliasing, and modify pszSrc to point
; 622  : 			// into the newly allocated buffer instead.
; 623  : 
; 624  : 			if(pszSrc == NULL)
; 625  : 				AtlThrow(E_INVALIDARG);
; 626  : 
; 627  : 			UINT nOldLength = GetLength();
; 628  : 			UINT_PTR nOffset = pszSrc-GetString();
; 629  : 			// If 0 <= nOffset <= nOldLength, then pszSrc points into our
; 630  : 			// buffer
; 631  : 
; 632  : 			PXSTR pszBuffer = GetBuffer( nLength );
; 633  : 			if( nOffset <= nOldLength )
; 634  : 			{
; 635  : 				CopyCharsOverlapped( pszBuffer, GetAllocLength(),
; 636  : 					pszBuffer+nOffset, nLength );
; 637  : 			}
; 638  : 			else
; 639  : 			{
; 640  : 				memcpy_s( pszBuffer, GetAllocLength() * sizeof( XCHAR ), pszSrc, nLength * sizeof( XCHAR ));
; 641  : 			}
; 642  : 			ReleaseBufferSetLength( nLength );
; 643  : 		}
; 644  : 	}
